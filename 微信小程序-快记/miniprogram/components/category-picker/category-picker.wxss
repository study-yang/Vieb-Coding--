.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.picker-overlay.show {
  opacity: 1;
  visibility: visible;
}

.picker-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-card);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-popup);
}

.picker-panel.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.picker-title {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-secondary);
  border-radius: 50%;
  background-color: var(--color-bg);
}

.tab-row {
  display: flex;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  margin-right: 16rpx;
  background-color: var(--color-bg);
  transition: all 0.2s;
}

.tab-item.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  flex: 1;
  overflow-y: auto;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: var(--radius-card);
  transition: transform 0.15s;
}

.category-item-hover {
  transform: scale(0.95);
}

.category-item.selected {
  background-color: var(--color-primary-light);
}

.category-emoji {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.category-item.selected .category-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}