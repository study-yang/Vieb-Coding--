.budget-bar-wrap {
  padding: 8rpx 0;
}

.budget-label {
  margin-bottom: 8rpx;
}

.budget-track {
  width: 100%;
  height: 16rpx;
  background-color: var(--color-bg);
  border-radius: 8rpx;
  overflow: hidden;
}

.budget-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease-out, background-color 0.3s;
  min-width: 0;
}

.budget-percent {
  margin-top: 8rpx;
  text-align: right;
}