.voice-wrap {
  position: relative;
}

/* === 麦克风按钮 === */
.mic-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, #FF8A5C 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
  transition: all 0.25s ease;
  user-select: none;
  -webkit-user-select: none;
}

.mic-btn-hover {
  transform: scale(0.92);
  opacity: 0.85;
}

.mic-btn.recording {
  animation: micPulse 1.5s ease-in-out infinite;
}

.mic-icon {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.mic-label {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* === 录音覆盖层 === */
.record-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-panel {
  width: 500rpx;
  padding: 60rpx 40rpx;
  background-color: var(--color-card);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: panelSlideUp 0.3s ease-out;
}

/* === 波形动画 === */
.wave-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.wave-bar {
  width: 8rpx;
  border-radius: 4rpx;
  background-color: var(--color-primary);
  animation: waveAnim 0.6s ease-in-out infinite alternate;
}

.wave-bar-1 { height: 30rpx; animation-delay: 0s; }
.wave-bar-2 { height: 50rpx; animation-delay: 0.1s; }
.wave-bar-3 { height: 70rpx; animation-delay: 0.2s; }
.wave-bar-4 { height: 50rpx; animation-delay: 0.3s; }
.wave-bar-5 { height: 30rpx; animation-delay: 0.4s; }

@keyframes waveAnim {
  0% { height: 20rpx; opacity: 0.5; }
  100% { height: 70rpx; opacity: 1; }
}

/* === 时长 === */
.record-duration {
  font-size: 64rpx;
  font-weight: var(--font-weight-bold);
  font-variant-numeric: tabular-nums;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

/* === 实时文本 === */
.record-text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  text-align: center;
  min-height: 48rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* === 提示 === */
.record-hint {
  font-size: var(--font-size-caption);
  color: var(--color-text-hint);
  margin-bottom: 32rpx;
}

/* === 停止按钮 === */
.stop-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-danger);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.3);
  transition: all 0.2s;
}

.stop-btn:active {
  transform: scale(0.9);
}

.stop-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* === 动画 === */
@keyframes micPulse {
  0% { box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3); }
  50% { box-shadow: 0 4rpx 40rpx rgba(255, 107, 53, 0.5); }
  100% { box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3); }
}

@keyframes panelSlideUp {
  0% { transform: translateY(60rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}
