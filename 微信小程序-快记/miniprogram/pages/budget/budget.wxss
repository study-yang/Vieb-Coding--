.budget-input-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.input-prefix {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-right: 12rpx;
}

.budget-input {
  flex: 1;
  height: 80rpx;
  background-color: var(--color-bg);
  border-radius: var(--radius-key);
  padding: 0 24rpx;
  font-size: var(--font-size-title);
  font-weight: 600;
  color: var(--color-text-primary);
}

.input-save-btn {
  padding: 16rpx 32rpx;
  font-size: var(--font-size-body);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 12rpx 0;
}

.quick-tag {
  padding: 8rpx 24rpx;
  background-color: var(--color-bg);
  border-radius: var(--radius-button);
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.quick-tag:active {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

.empty-hint {
  text-align: center;
  padding: 24rpx 0;
}

.remind-row {
  padding: 8rpx 0;
}

.remind-label {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
}

.remind-info {
  flex: 1;
}

.note-placeholder {
  color: var(--color-text-hint);
}