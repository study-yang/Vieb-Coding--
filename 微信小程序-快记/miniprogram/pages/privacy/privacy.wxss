.card {
  padding: 32rpx;
}

.doc-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.doc-date {
  text-align: center;
  margin-bottom: 32rpx;
}

.doc-section {
  margin-bottom: 32rpx;
}

.doc-h2 {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.doc-h3 {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 16rpx 0 8rpx;
}

.doc-p {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  margin-bottom: 8rpx;
}
