.profile-card {
  padding: 32rpx;
}

.avatar-btn {
  width: 96rpx;
  height: 96rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: none;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-text {
  margin-left: 20rpx;
  flex: 1;
}

.nickname-input {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.stats-row {
  text-align: center;
}

.stat-item {
  flex: 1;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
}

.stat-label {
  margin-top: 4rpx;
}

/* 数据概览 */
.overview-card {
  padding: 24rpx;
}

.card-title {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.overview-item {
  background-color: var(--color-bg);
  border-radius: var(--radius-key);
  padding: 20rpx 16rpx;
  text-align: center;
}

.overview-value {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-bold);
  font-variant-numeric: tabular-nums;
  margin-bottom: 4rpx;
}

.overview-label {
  color: var(--color-text-secondary);
}

.overview-top {
  background-color: var(--color-bg);
  border-radius: var(--radius-key);
  padding: 16rpx 20rpx;
}

.top-left {
  align-items: center;
}

.top-tag {
  font-size: var(--font-size-caption);
  color: #FFFFFF;
  background-color: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.top-name {
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.top-amount {
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-bold);
  font-variant-numeric: tabular-nums;
}

/* 菜单 */
.menu-card {
  padding: 0;
}

.menu-item {
  padding: 28rpx 24rpx;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
}

.menu-right {
  align-items: center;
}

.menu-desc {
  color: var(--color-text-secondary);
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--color-text-hint);
}

/* 主题选择弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.picker-panel {
  width: 100%;
  background-color: var(--color-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.picker-title {
  font-size: var(--font-size-title);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  text-align: center;
}

.picker-options {
  display: flex;
  gap: 16rpx;
}

.picker-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: var(--radius-button);
  background-color: var(--color-bg);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.picker-option.active {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.picker-option-name {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  margin-right: 8rpx;
}

.picker-option.active .picker-option-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.picker-option-check {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.version {
  text-align: center;
  padding: 48rpx;
}

/* 反馈弹窗 */
.feedback-panel {
  width: 100%;
  background-color: var(--color-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.feedback-desc {
  text-align: center;
  margin-bottom: 24rpx;
}

.feedback-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border-radius: var(--radius-key);
  background-color: var(--color-bg);
  border: 2rpx solid var(--color-divider);
  color: var(--color-text-primary);
  font-size: var(--font-size-body);
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.feedback-contact {
  width: 100%;
  padding: 20rpx;
  border-radius: var(--radius-key);
  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-size: var(--font-size-body);
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.feedback-actions {
  gap: 16rpx;
}

.feedback-btn {
  flex: 1;
}
